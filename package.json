{
  "name": "hexatodo-backend",
  "version": "1.0.0",
  "description": "Projeto toDoList utilizando arquitetura hexagonal bem estruturada",
  "main": "index.js",
  "scripts": {
    "build": "rimraf dist && tsc && tsc-alias",
    "start": "node --env-file=.env dist/server.js",
    "dev": "tsx watch --env-file=.env src/interfaces/http/server.ts",
    "test": "node --env-file=.env node_modules/.bin/jest",
    "test:watch": "node --env-file=.env node_modules/.bin/jest --watch",
    "test:cov": "node --env-file=.env node_modules/.bin/jest --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "type-check": "tsc --noEmit",
    "prepare": "husky"
  },
  "keywords": [
    "To",
    "Do",
    "ToDoList",
    "hexaTodDo"
  ],
  "author": "Roseno Silva da Silva",
  "license": "ISC",
  "type": "module",
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.6.2",
    "uuid": "^14.0.0",
    "winston": "^3.19.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/mongoose": "^5.11.96",
    "@types/node": "^25.7.0",
    "@types/winston": "^2.4.4",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "lint-staged": "^17.0.4",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "ts-jest": "^29.4.9",
    "tsc-alias": "^1.8.17",
    "tsx": "^4.22.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2"
  }
}
